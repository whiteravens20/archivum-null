{
  "name": "archivum-null-backend",
  "version": "1.0.0",
  "description": "Zero trust file relay — backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^5.8.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "nanoid": "^5.1.6",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "pino-pretty": "^13.0.0",
    "eslint": "^10.0.2",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.56.1",
    "globals": "^17.4.0",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  }
}
