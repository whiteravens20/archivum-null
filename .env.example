# ── Archivum Null ── Zero Trust File Relay ── .env.example ──
#
# Copy this file to .env and fill in your values.
#
# VITE_ PREFIX EXPLAINED
#   Variables read by the backend start with no prefix (MAX_FILE_SIZE, etc.).
#   Variables that also need to appear in the browser bundle must be duplicated
#   with the VITE_ prefix — Vite bakes them in at build time.
#   Rule of thumb: whenever you change a backend value that has a VITE_ mirror
#   below, change both lines to the same value.
#
# [PROD] = review before going to production
# [DEV]  = safe default for local development, change for production


# ── File size ─────────────────────────────────────────────────────────────────

MAX_FILE_SIZE=104857600          # bytes — backend enforcement
VITE_MAX_FILE_SIZE=104857600     # mirror of MAX_FILE_SIZE — frontend enforcement


# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Leave as-is to disable Turnstile (backend detects the dummy key and skips verification).

TURNSTILE_SECRET=0x0000000000000000000000          # [PROD] server-side secret — never expose this
TURNSTILE_SITE_KEY=0x0000000000000000000000        # [PROD] public site key — sent to backend via .env only
VITE_TURNSTILE_SITE_KEY=0x0000000000000000000000   # mirror of TURNSTILE_SITE_KEY — embedded in frontend bundle
TURNSTILE_HOSTNAME=                                # [PROD] expected hostname in Turnstile response (e.g. example.com); leave empty to skip check


# ── Rate limiting (in-memory, per IP) ─────────────────────────────────────────

RATE_LIMIT_WINDOW=60          # seconds per window
RATE_LIMIT_MAX=10             # max upload (POST /api/vault) requests per window per IP
RATE_LIMIT_API_MAX=120        # max general API requests per window per IP
RATE_LIMIT_DOWNLOAD_MAX=30    # max download requests per window per IP


# ── Vault defaults ────────────────────────────────────────────────────────────

DEFAULT_TTL=86400            # seconds — pre-selected TTL in the UI (24 h)
VITE_DEFAULT_TTL=86400       # mirror of DEFAULT_TTL

MAX_TTL=604800               # seconds — hard upper limit the backend enforces (7 days)

DEFAULT_MAX_DOWNLOADS=10     # pre-selected download limit in the UI
VITE_DEFAULT_MAX_DOWNLOADS=10  # mirror of DEFAULT_MAX_DOWNLOADS


# ── Admin panel ───────────────────────────────────────────────────────────────

ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY   # [PROD] required — panel is disabled if empty or default


# ── Storage ───────────────────────────────────────────────────────────────────

STORAGE_PATH=/data/vaults    # path inside container; map via Docker volume


# ── Network ───────────────────────────────────────────────────────────────────

# [PROD] Set to your tunnel / private interface IP so the port is not exposed on 0.0.0.0
# [DEV]  Keep as 0.0.0.0 so the container is reachable from the host
BIND_ADDRESS=0.0.0.0

PORT=3000

# How many reverse-proxy hops to trust when reading X-Forwarded-For.
# 1 = trust only the nearest proxy (default, correct for a single nginx/Caddy in front).
# Do NOT set to 0 or a very high value in production.
TRUST_PROXY=1


# ── Runtime ───────────────────────────────────────────────────────────────────

NODE_ENV=production    # [DEV] set to development for verbose logs and hot-reload
