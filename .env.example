# ── Archivum Null ── Zero Trust File Relay ──

# Maximum file size in bytes (default 100MB)
MAX_FILE_SIZE=104857600

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=0x0000000000000000000000
TURNSTILE_SECRET=0x0000000000000000000000

# Rate limiting (per IP, in-memory only)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=10

# Default vault TTL in seconds (default 24h)
DEFAULT_TTL=86400

# Maximum vault TTL in seconds (default 7 days)
MAX_TTL=604800

# Maximum downloads per vault (default)
DEFAULT_MAX_DOWNLOADS=10

# Admin panel credentials (HTTP Basic Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY

# Storage path (inside container)
STORAGE_PATH=/data/vaults

# Bind address — PRODUCTION: set to your tunnel/private interface IP, DEV: 0.0.0.0
BIND_ADDRESS=0.0.0.0

# Port
PORT=3000

# Node environment
NODE_ENV=production
